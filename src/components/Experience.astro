---
type Out = { key: string; value: string };

interface JobExp {
    period: Out;
    role: Out;
    company: Out;
    description: Out;
}

interface Props {
    title: Out;
    jobs: JobExp[];
}

const { title, jobs } = Astro.props as Props;
const sectionId = title.value.toLowerCase();
---

<section id={sectionId} class="scroll-mt-50 py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-green-500 text-xl font-mono mb-8 flex items-center gap-3">
        <span>[</span>
        <span>{title.value.toUpperCase()}</span>
        <span>]</span>
      </h2>

      <div class="space-y-4 font-mono text-sm">
        {jobs.map((job, index) => (
          <div class="border border-dashed border-green-900/30 bg-secondary/20 p-4 hover:border-green-500/50 hover:bg-secondary/40 transition-all">
            <div class="flex items-start gap-4">
              <span class="text-green-500/50 text-xs">
                [{String(index + 1).padStart(2, '0')}]
              </span>
              <div class="flex-1 space-y-2">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="text-cyan-500">{job.role.value}</span>
                  <span class="text-green-500/30">@</span>
                  <span class="text-green-500">{job.company.value}</span>
                </div>
                <div class="text-green-500/50 text-xs">
                  ┌─ {job.period.value}
                </div>
                <div class="text-green-500/60 text-xs">
                  │
                </div>
                <div class="text-green-500/60 text-xs pl-2">
                  {job.description.value}
                </div>
                <div class="text-green-500/50 text-xs">
                  └────────
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
</section>
