---
import Layout from "@/src/layouts/Layout.astro";
import Header from "@/src/components/Header.astro";
import Footer from "@/src/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const nav = [
  { path: `/`, text: "home" },
  { path: `#contact`, text: "contact" },
];

const footerContent = {
  id: "contact",
  status: "[online] available for freelance",
  email_label: "email:",
  email_url: "mailto:hi@anson.im",
  github_label: "github",
  github_url: "https://github.com/anson-im",
  x_label: "twitter",
  x_url: "https://x.com/anson_im",
  linkedin_label: "linkedin",
  linkedin_url: "https://linkedin.com/in/anson-im",
};
---

<Layout
  locale="en"
  title="./blog - Anson"
  description="Developer terminal - blog posts"
>
  <div class="scanlines"></div>
  <Header nav={nav} locales={["en"]} currentLocale="en" />

  <main class="container mx-auto px-4 py-20 max-w-4xl font-mono">
    <div class="mb-8">
      <pre class="text-green-500 text-sm mb-4">
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ  в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—    в”Ӯ
в”Ӯ  в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ    в”Ӯ
в”Ӯ  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—      в”Ӯ
в”Ӯ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ      в”Ӯ
в”Ӯ  в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—    в”Ӯ
в”Ӯ  в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ    в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      </pre>
      <p class="terminal-cursor text-green-500">./blog/list --all</p>
    </div>

    <div class="space-y-6">
      <div class="text-amber-500 mb-4">// Found {posts.length} entries:</div>

      {posts.map((post, index) => (
        <article class="border border-green-900/50 bg-secondary/30 p-4 hover:border-green-500/50 transition-colors">
          <div class="flex items-start gap-4">
            <span class="text-green-500/70 text-sm font-mono">
              [{String(index + 1).padStart(2, '0')}]
            </span>
            <div class="flex-1">
              <a href={`/blog/${post.slug}`} class="block group">
                <div class="flex items-center gap-3 text-sm text-green-500/60 mb-2 font-mono">
                  <span>в”Ңв”Җ {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit"
                  })}</span>
                  {post.data.lang === "zh" && <span class="text-amber-500">[ZH]</span>}
                  {post.data.lang === "en" && <span class="text-cyan-500">[EN]</span>}
                  <span class="text-green-500">в”ҳ</span>
                </div>
                <h2 class="text-lg font-mono text-green-500 group-hover:text-cyan-500 group-hover:underline transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-green-500/60 text-sm mt-2 font-mono">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex gap-2 mt-3 text-xs">
                    {post.data.tags.map(tag => (
                      <span class="px-2 py-0.5 bg-green-950/50 text-green-500 font-mono">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-green-500/60 font-mono">
        <p class="terminal-cursor">./blog: No entries found.</p>
      </div>
    )}

    <div class="mt-12 pt-8 border-t border-dashed border-green-900/30">
      <pre class="text-green-500/50 text-xs">
в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  End of list. Press [HOME] to return.
в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      </pre>
    </div>
  </main>

  <Footer {...footerContent} />
</Layout>
