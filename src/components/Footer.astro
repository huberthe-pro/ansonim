---
type Option = { key:string; value:string }

interface Props {
    status: string | Option;
    id:string;
    email_label?: string | Option;
    email_url?: string | Option;
    github_label?: string | Option;
    github_url?: string | Option;
    x_label?: string | Option;
    x_url?: string | Option;
}

const { status, email_label, email_url, github_label, github_url, x_label, x_url, id } = Astro.props as Props

const statusValue = typeof status === 'string' ? status : status.value;
const emailUrlValue = typeof email_url === 'string' ? email_url : email_url?.value;
const emailLabelValue = typeof email_label === 'string' ? email_label : email_label?.value;
const githubUrlValue = typeof github_url === 'string' ? github_url : github_url?.value;
const githubLabelValue = typeof github_label === 'string' ? github_label : github_label?.value;
const xUrlValue = typeof x_url === 'string' ? x_url : x_url?.value;
const xLabelValue = typeof x_label === 'string' ? x_label : x_label?.value;
---

<footer
    id={id}
    class="my-24 border-t border-dashed border-green-900/30 pt-8 text-xs font-mono"
>
    <div class="max-w-2xl mx-auto space-y-4">
        <div class="text-green-500/60">
            <span class="inline-block w-2 h-2 bg-green-500 mr-2 animate-pulse"></span>
            {statusValue}
            <span class="inline-block w-2 h-2 bg-green-500 ml-2 animate-pulse"></span>
        </div>

        <div class="border border-dashed border-green-900/30 bg-secondary/20 p-4">
            <div class="text-green-500/40 mb-2">[CONTACT LINKS]</div>
            <div class="space-y-1">
                {emailUrlValue && emailLabelValue && (
                    <div class="flex gap-2">
                        <span class="text-green-500/60">EMAIL:</span>
                        <a href={emailUrlValue} class="text-cyan-500 hover:text-green-500 hover:underline">
                            {emailLabelValue}
                        </a>
                    </div>
                )}

                {githubUrlValue && githubLabelValue && (
                    <div class="flex gap-2">
                        <span class="text-green-500/60">GITHUB:</span>
                        <a href={githubUrlValue} rel="nofollow" class="text-cyan-500 hover:text-green-500 hover:underline">
                            {githubLabelValue}
                        </a>
                    </div>
                )}

                {xUrlValue && xLabelValue && (
                    <div class="flex gap-2">
                        <span class="text-green-500/60">TWITTER:</span>
                        <a href={xUrlValue} rel="nofollow" class="text-cyan-500 hover:text-green-500 hover:underline">
                            {xLabelValue}
                        </a>
                    </div>
                )}

            </div>
        </div>

        <pre class="text-green-500/30 text-center">
─────────────────────────────────────────
© 2026 Made with ❤️ by Anson | v0.10.13 |
─────────────────────────────────────────
        </pre>
    </div>
</footer>
