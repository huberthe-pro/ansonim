---
import Layout from "@/src/layouts/Layout.astro";
import Header from "@/src/components/Header.astro";
import Footer from "@/src/components/Footer.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const locale = post.data.lang;

const nav = [
  { path: `/`, text: locale === "en" ? "About" : "关于" },
  { path: `/blog`, text: locale === "en" ? "Blog" : "博客" },
  { path: `#experience`, text: locale === "en" ? "Experience" : "经历" },
  { path: `#projects`, text: locale === "en" ? "Projects" : "项目" },
  { path: `#contact`, text: locale === "en" ? "Contact" : "联系" },
];

const footerContent = {
  id: "contact",
  status: locale === "en" ? "Available for freelance" : "接受兼职",
  email_label: locale === "en" ? "Email" : "邮箱",
  email_url: "mailto:hi@anson.im",
  github_label: "GitHub",
  github_url: "https://github.com/anson-im",
  x_label: "X",
  x_url: "https://x.com/anson_im",
  linkedin_label: locale === "en" ? "Linkedin" : "领英",
  linkedin_url: "https://linkedin.com/in/anson-im",
};
---

<Layout
  locale={locale}
  title={post.data.title}
  description={post.data.description}
  alternateLinks={[
    { href: "/en", hreflang: "en" },
    { href: "/zh", hreflang: "zh" },
  ]}
>
  <Header nav={nav} locales={["en", "zh"]} currentLocale={locale} />

  <article class="container mx-auto px-4 py-16 max-w-3xl">
    <a href="/blog" class="inline-flex items-center text-green-600 dark:text-green-400 hover:underline mb-8">
      ← {locale === "en" ? "Back to Blog" : "返回博客"}
    </a>

    <header class="mb-8">
      <span class="inline-block px-2 py-1 bg-gray-200 dark:bg-gray-800 rounded text-sm mb-4 uppercase">
        {locale === "en" ? "EN" : "中文"}
      </span>
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString(locale === "en" ? "en-US" : "zh-CN", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <time datetime={post.data.updatedDate.toISOString()}>
              {locale === "en" ? "Updated" : "更新"} {post.data.updatedDate.toLocaleDateString(locale === "en" ? "en-US" : "zh-CN")}
            </time>
          </>
        )}
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex gap-2 mt-4">
          {post.data.tags.map(tag => (
            <span class="px-3 py-1 bg-gray-200 dark:bg-gray-800 rounded-full text-sm">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>

  <Footer {...footerContent} />
</Layout>
