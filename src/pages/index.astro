---
import Layout from "@/src/layouts/Layout.astro";
import Header from "@/src/components/Header.astro";
import Hero from "@/src/components/Hero.astro";
import Projects from "@/src/components/Projects.astro";
import Experience from "@/src/components/Experience.astro";
import Footer from "@/src/components/Footer.astro";
import Skills from "@/src/components/Skills.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const nav = [
  { path: `/`, text: "home" },
  { path: `/blog`, text: "blog" },
  { path: `#contact`, text: "contact" },
];

const heroProps = {
  name: "Anson Ho",
  title: "Agentic Coding Engineer",
  p1: "人生的意义就是探索和体验",
  p2: "From Google Glass OS to apps serving 500M+ users, now building the email infrastructure for AI agents.",
  p3: "I ship products with AI agents. Currently building AgentsMail — free, encrypted email for every AI agent.",
};

const projects = [
  {
    name: "AgentsMail",
    description:
      "Free email service for AI agents. One API call to get a mailbox and start sending. Encrypted, zero friction, open source.",
    link: "https://agentsmail.org",
  },
  {
    name: "agents-mail (open source)",
    description:
      "The open-source backend powering AgentsMail. Cloudflare Workers + D1, action-oriented API, trust tier system.",
    link: "https://github.com/huberthe-pro/agents-mail",
  },
  {
    name: "AgentsMail ClawHub Skill",
    description:
      "Install this skill and your AI agent gets its own email in seconds. 40+ installs on ClawHub.",
    link: "https://clawhub.ai/huberthe-pro/agentsmail",
  },
];

const projectsProps = {
  title: { key: "projects.title", value: "Projects" },
  projects,
};

const experienceData = {
  title: { key: "experience.title", value: "Experience" },
  jobs: [
    {
      period: { key: "experience.item_1.period", value: "2025 — now" },
      role: { key: "experience.item_1.role", value: "Founder & Agentic Coding Engineer" },
      company: { key: "experience.item_1.company", value: "AgentsMail" },
      description: {
        key: "experience.item_1.description",
        value:
          "Building the email infrastructure for AI agents. Open source, free, encrypted. Cloudflare Workers + D1.",
      },
    },
    {
      period: { key: "experience.item_2.period", value: "Previous" },
      role: { key: "experience.item_2.role", value: "Google Glass OS Developer" },
      company: { key: "experience.item_2.company", value: "Google" },
      description: {
        key: "experience.item_2.description",
        value:
          "Developed for the Google Glass platform, pioneering wearable computing experiences.",
      },
    },
    {
      period: { key: "experience.item_3.period", value: "Previous" },
      role: { key: "experience.item_3.role", value: "Product & Engineering Lead" },
      company: { key: "experience.item_3.company", value: "Various" },
      description: {
        key: "experience.item_3.description",
        value:
          "Planned and developed dozens of apps and mini-programs, serving over 500 million users.",
      },
    },
  ],
};

const footerContent = {
  id: "contact",
  status: "[online] building AgentsMail",
  email_label: "beacharsiu@gmail.com",
  email_url: "mailto:beacharsiu@gmail.com",
  github_label: "huberthe-pro",
  github_url: "https://github.com/huberthe-pro",
  x_label: "@BeACharsiu",
  x_url: "https://x.com/BeACharsiu",
};

const skills = [
  {
    title: { value: "Agentic Development" },
    category: { value: "AI" },
    description: { value: "Claude Code, OpenClaw, Multi-agent Orchestration" },
    experience_years: { value: "2" },
    experience_label: { value: "years of experience" },
  },
  {
    title: { value: "TypeScript" },
    category: { value: "Language" },
    description: { value: "Cloudflare Workers, Edge Computing, API Design" },
    experience_years: { value: "5" },
    experience_label: { value: "years of experience" },
  },
  {
    title: { value: "Product Engineering" },
    category: { value: "Product" },
    description: { value: "0→1 Product Design, Apps & Mini-programs, 500M+ Users" },
    experience_years: { value: "10+" },
    experience_label: { value: "years of experience" },
  },
  {
    title: { value: "Next.js & React" },
    category: { value: "Frontend" },
    description: { value: "App Router, Server Components, Tailwind, shadcn/ui" },
    experience_years: { value: "5" },
    experience_label: { value: "years of experience" },
  },
  {
    title: { value: "Cloud Infrastructure" },
    category: { value: "DevOps" },
    description: { value: "Cloudflare Workers, D1, Vercel, Email Routing" },
    experience_years: { value: "5" },
    experience_label: { value: "years of experience" },
  },
  {
    title: { value: "Email & Security" },
    category: { value: "Security" },
    description: { value: "DKIM/SPF/DMARC, AES-256-GCM, HMAC-SHA256, Trust Systems" },
    experience_years: { value: "3" },
    experience_label: { value: "years of experience" },
  },
];
---

<Layout
  title="Anson Ho - Agentic Coding Engineer"
  description="Building AgentsMail — free, encrypted email for AI agents"
>
  <div class="scanlines"></div>
  <Header nav={nav} />
  <main class="min-h-screen">
    <Hero {...heroProps} />
    <section class="mx-auto max-w-2xl px-6 py-12">
      <h2 class="text-xl font-bold mb-6 text-green-400">Latest</h2>
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="block mb-6 group">
          <h3 class="text-lg font-semibold group-hover:text-green-400 transition-colors">{post.data.title}</h3>
          <p class="text-sm text-gray-400 mt-1">{post.data.description}</p>
          <time class="text-xs text-gray-500 mt-1 block">{post.data.pubDate.toISOString().split('T')[0]}</time>
        </a>
      ))}
    </section>
    <Experience {...experienceData} />
    <Projects {...projectsProps} />
    <Skills heading={{ value: "Skills" }} content={skills} />
  </main>

  <Footer {...footerContent} />
</Layout>
