---
type Option = { key: string; value: string | number };

interface Content {
    title: Option;
    category: Option;
    description: Option;
    experience_years: Option;
    experience_label: Option;
}

interface Props {
    heading: Option;
    content: Content[];
}

const { heading, content } = Astro.props as Props;
---

<section class="py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-green-500 text-xl font-mono mb-8 flex items-center gap-3">
        <span>[</span>
        <span>{heading.value.toUpperCase()}</span>
        <span>]</span>
      </h2>

      <div class="border border-dashed border-green-900/30 bg-secondary/20 p-6 font-mono text-sm">
        <div class="text-green-500/40 text-xs mb-4">
          // Loaded modules: {content.length}
        </div>

        <div class="space-y-3">
          {content.map((skill, index) => (
            <div class="border-b border-green-900/20 pb-3 last:border-0 last:pb-0">
              <div class="flex items-center gap-4 text-xs">
                <span class="text-green-500/50 w-6">
                  [{String(index + 1).padStart(2, '0')}]
                </span>
                <span class="text-cyan-500 flex-1">
                  {skill.title.value}
                </span>
                <span class="text-green-500/60 px-2 py-0.5 bg-green-950/30">
                  {skill.category.value}
                </span>
              </div>
              <div class="ml-10 mt-1">
                <div class="text-green-500/50 text-xs mb-1">
                  └─ {skill.description.value}
                </div>
                <div class="text-green-500/40 text-xs">
                  └─ Level: {skill.experience_years.value} {skill.experience_label.value}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-4 text-green-500/30 text-xs">
          ┌─────────────────────────────────┐
          │ All systems operational.         │
          └─────────────────────────────────┘
        </div>
      </div>
    </div>
</section>
