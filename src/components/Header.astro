---
interface NavItem {
  path: string;
  text: string;
}

interface Props {
  nav: NavItem[];
}

const { nav } = Astro.props as Props;
---

<header class="py-8 flex items-center justify-center flex-col md:flex-row fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl bg-background z-40 border-b border-dashed border-green-900/30">
  <div class="flex items-center gap-6 text-sm">
    {nav.map((item, index) => (
      <>
        <a
          class="text-green-500/70 hover:text-cyan-500 hover:underline transition-all text-xs md:text-sm"
          href={item.path}
        >
          {item.text}
        </a>
        {index < nav.length - 1 && <span class="text-green-500/30">/</span>}
      </>
    ))}
  </div>
  <div class="absolute -bottom-6 left-0 w-full h-6 pointer-events-none bg-linear-to-b from-background via-background/90 to-transparent"></div>
</header>
