---
type Item = {
    nameKey: string;
    descriptionKey: string;
    name: string;
    description: string;
    link?: string;
};

interface Props {
    title: { key: string; value: string };
    projects: Item[];
}

const { title, projects } = Astro.props as Props;
const sectionId = title.value.toLowerCase();
---

<section id={sectionId} class="scroll-mt-50 py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-green-500 text-xl font-mono mb-8 flex items-center gap-3">
        <span>[</span>
        <span>{title.value.toUpperCase()}</span>
        <span>]</span>
      </h2>

      <div class="border border-dashed border-green-900/30 bg-secondary/20 p-6">
        <div class="text-green-500/40 text-xs font-mono mb-4">
          // Total projects: {projects.length}
        </div>

        <ul class="space-y-4 font-mono text-sm">
          {
            projects.map((project, index) => (
              <li class="group border-l-2 border-green-900/30 pl-4 hover:border-cyan-500 hover:bg-secondary/40 transition-all">
                {project.link ? (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block"
                  >
                    <div class="flex items-start gap-3">
                      <span class="text-green-500/50">[{String(index + 1).padStart(2, '0')}]</span>
                      <div class="flex-1">
                        <div class="text-green-500 group-hover:text-cyan-500 transition-colors mb-1">
                          {project.name}
                        </div>
                        <div class="text-green-500/60 text-xs">
                          {project.description}
                        </div>
                      </div>
                      <span class="text-green-500/30 group-hover:text-cyan-500">→</span>
                    </div>
                  </a>
                ) : (
                  <div class="flex items-start gap-3">
                    <span class="text-green-500/50">[{String(index + 1).padStart(2, '0')}]</span>
                    <div class="flex-1">
                      <div class="text-green-500 mb-1">
                        {project.name}
                      </div>
                      <div class="text-green-500/60 text-xs">
                        {project.description}
                      </div>
                    </div>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
</section>
